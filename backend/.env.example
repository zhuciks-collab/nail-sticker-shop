# ============================================================
# Supabase environment variables
# Copy this file to .env.local and fill in your values.
# Find these in: Supabase Dashboard → Project Settings → API
# ============================================================

# ── Public (safe to expose to the browser) ──────────────────
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://bebaqmrywywoxcgkabdt.supabase.co

# The anon/public key — used in client-side queries
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJlYmFxbXJ5d3l3b3hjZ2thYmR0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzODA5NjEsImV4cCI6MjA5MDk1Njk2MX0.yYFa3TpgY15kX4K03A07RGjoh_9oN0mQIjOwnsSdqrA
# ── Server-only (NEVER prefix with NEXT_PUBLIC_) ─────────────
